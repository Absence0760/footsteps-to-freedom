{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "FTF",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev --port 7777",
		"build": "vite build",
		"preview": "vite preview --port 8888",
