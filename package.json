		"mdsvex": "^0.12.7",
		"normalize.css": "^8.0.1",
		"svelte": "^5.55.3",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	},
	"type": "module",
	"dependencies": {
		"isomorphic-dompurify": "^3.8.0"
	}
