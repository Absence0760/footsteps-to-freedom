# Application Settings
APP_PORT=3000
ENV=development

# Database Settings (optional - remove if not using database)
DB_HOST=postgres
DB_PORT=5432
DB_USER=appuser
DB_PASSWORD=change_this_password
DB_NAME=appdb
DATABASE_URL=postgres://appuser:change_this_password@postgres:5432/appdb?sslmode=disable

# AWS Settings (for production deployment)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your_aws_account_id

# Application Secrets (change these!)
JWT_SECRET=your_jwt_secret_here
API_KEY=your_api_key_here

# Admin Credentials (CHANGE THESE IN PRODUCTION!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
